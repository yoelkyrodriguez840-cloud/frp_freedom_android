# ============================================
# ARCHIVO DE CONFIGURACIÓN DE VERSIÓN
# ============================================
# Modifica solo este archivo para cambiar la versión
# de la aplicación sin tocar el código fuente
# ============================================

# Versión de la aplicación (Semantic Versioning)
# Formato: MAJOR.MINOR.PATCH
# Ejemplo: 1.0.0, 2.1.3, 1.0.0-beta.1
APP_VERSION=1.0.0

# Número de build (incrementar manualmente o automático en CI)
# Este número se usa para el versionCode de Android
# BUILD_NUMBER=1
