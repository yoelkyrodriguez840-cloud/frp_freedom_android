# ============================================
# CONFIGURACIÓN DE VERSIÓN PARA FRP FREEDOM
# ============================================

# Versión de la aplicación (semver)
APP_VERSION=1.0.0

# Número de build (incrementar automáticamente en CI/CD)
BUILD_NUMBER=1

# ============================================
# CONFIGURACIÓN DE ANDROID
# ============================================

# Versión mínima de Android SDK
ANDROID_MIN_SDK=24

# Versión objetivo de Android SDK
ANDROID_TARGET_SDK=34

# Versión de compilación de Android SDK
ANDROID_COMPILE_SDK=34

# ============================================
# CONFIGURACIÓN DE FLET
# ============================================

# Modo de depuración de Flet
FLET_VERBOSE=0
FLET_LOG_LEVEL=INFO

# ============================================
# CONFIGURACIÓN DE GITHUB ACTIONS
# ============================================

# Token de GitHub (se usa en CI/CD)
GITHUB_TOKEN=

# Repositorio de GitHub
GITHUB_REPOSITORY=
